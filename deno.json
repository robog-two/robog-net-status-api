{
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.8.5",
    "handlebars": "npm:handlebars@^4.7.8",
    "hono": "jsr:@hono/hono@^4.8.5"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read=static,views main.ts",
    "dev": "deno run --watch --allow-net --allow-read=static,views main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
